{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "JWT_SECRET",
    "COOKIE_SECRET",
    "DB_NAME",
    "STORE_CORS",
    "ADMIN_CORS",
    "AUTH_CORS",
    "REDIS_URL"
  ],
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "env": [
        "DATABASE_URL",
        "JWT_SECRET",
        "COOKIE_SECRET",
        "DB_NAME",
        "STORE_CORS",
        "ADMIN_CORS",
        "AUTH_CORS",
        "REDIS_URL",
        "NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_MEDUSA_BACKEND_URL",
        "NEXT_PUBLIC_BASE_URL",
        "NEXT_PUBLIC_DEFAULT_REGION",
        "NEXT_PUBLIC_MEDUSA_PAYMENTS_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_MEDUSA_PAYMENTS_ACCOUNT_ID",
        "REVALIDATE_SECRET"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        ".medusa/server/**",
        ".medusa/admin/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$", ".eslintrc*", "eslint.config.*"]
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", "jest.config.*"],
      "outputs": ["coverage/**"]
    },
    "test:integration:http": {
      "cache": false
    },
    "test:integration:modules": {
      "cache": false
    },
    "test:unit": {
      "inputs": ["$TURBO_DEFAULT$", "jest.config.*"]
    },
    "clean": {
      "cache": false
    }
  }
}
